{
  "name": "@unirate/sveltekit",
  "version": "0.1.0",
  "description": "SvelteKit integration for the UniRate currency-exchange API. Server-side getRate/convert helpers for load functions, createCurrencyHandle() geo-detection hook, API route proxy, and <Currency/> + <Rate/> Svelte 5 components. Zero runtime deps.",
  "type": "module",
  "license": "MIT",
  "author": "UniRate (https://unirateapi.com)",
  "homepage": "https://github.com/UniRate-API/sveltekit-unirate#readme",
  "bugs": "https://github.com/UniRate-API/sveltekit-unirate/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UniRate-API/sveltekit-unirate.git"
  },
  "keywords": [
    "sveltekit",
    "svelte",
    "svelte5",
    "unirate",
    "currency",
    "currency-converter",
    "exchange-rates",
    "forex",
    "fx",
    "money",
    "fintech",
    "load-function",
    "hooks"
  ],
  "files": [
    "dist",
    "components",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./Currency.svelte": "./components/Currency.svelte",
    "./Rate.svelte": "./components/Rate.svelte",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-components.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "@sveltejs/kit": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
